#!/usr/bin/env node
//
// Generates agent-facing markdown versions of all docs pages.
// Called after vitepress build.
//
// For each source .md file:
//   - VitePress home layout frontmatter is converted to markdown
//     (hero name/text/tagline/actions and features)
//   - Other frontmatter (title, outline, etc.) is stripped
//   - <style> and <script> blocks are stripped
//   - HTML tags are stripped, text content preserved
//   - Consecutive blank lines are collapsed
//
// Output goes to .vitepress/dist/ at the same relative paths.

import { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync, statSync } from 'node:fs';
import { join, relative, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';

const docsDir = dirname(fileURLToPath(import.meta.url));
const distDir = join(docsDir, '.vitepress/dist');

if (!existsSync(distDir)) {
  console.error(`Error: dist directory not found at ${distDir}`);
  console.error('Run vitepress build before generate_agent_md');
  process.exit(1);
}

function findMdFiles(dir) {
  const skip = new Set(['.vitepress', 'node_modules']);
  const results = [];
  for (const entry of readdirSync(dir)) {
    if (skip.has(entry)) continue;
    const full = join(dir, entry);
    if (statSync(full).isDirectory()) {
      results.push(...findMdFiles(full));
    } else if (entry.endsWith('.md')) {
      results.push(full);
    }
  }
  return results;
}

function splitFrontmatter(content) {
  if (!content.startsWith('---\n')) return { yaml: null, body: content };
  const end = content.indexOf('\n---\n', 4);
  if (end === -1) return { yaml: null, body: content };
  return { yaml: content.slice(4, end), body: content.slice(end + 5) };
}

// Convert VitePress home layout YAML to markdown.
// Renders hero (name, text, tagline, actions) and features as real content.
function homeYamlToMarkdown(yaml) {
  const out = [];

  const name = yaml.match(/^  name:\s*(.+)$/m)?.[1]?.trim();
  const text = yaml.match(/^  text:\s*(.+)$/m)?.[1]?.trim();
  const tagline = yaml.match(/^  tagline:\s*(.+)$/m)?.[1]?.trim();

  if (name) out.push(`# ${name}`, '');
  if (text) out.push(text, '');
  if (tagline) out.push(tagline, '');

  const actions = [...yaml.matchAll(/    - theme: \w+\n      text: (.+)\n      link: (.+)/g)];
  if (actions.length > 0) {
    for (const m of actions) out.push(`- [${m[1].trim()}](${m[2].trim()})`);
    out.push('');
  }

  const featuresBlock = yaml.match(/^features:\n([\s\S]+)/m)?.[1] ?? '';
  const features = [...featuresBlock.matchAll(/  - title: (.+)\n    details: (.+)/g)];
  if (features.length > 0) {
    out.push('## Features', '');
    for (const m of features) out.push(`- **${m[1].trim()}**: ${m[2].trim()}`);
    out.push('');
  }

  return out.join('\n') + '\n';
}

function processBody(content) {
  const lines = content.split('\n');
  const out = [];
  let inStyle = false;
  let inScript = false;
  let inFence = false;
  let prevBlank = false;
  let started = false;

  for (const line of lines) {
    if (!inStyle && !inScript && /^<style/.test(line)) {
      inStyle = true;
      continue;
    }
    if (inStyle && /^<\/style>/.test(line)) {
      inStyle = false;
      continue;
    }
    if (inStyle) continue;

    if (!inStyle && !inScript && /^<script/.test(line)) {
      inScript = true;
      continue;
    }
    if (inScript && /^<\/script>/.test(line)) {
      inScript = false;
      continue;
    }
    if (inScript) continue;

    if (/^(`{3,}|~{3,})/.test(line)) inFence = !inFence;

    let stripped;
    if (inFence) {
      stripped = line;
    } else {
      // Parse CommonMark code spans and extract content without backtick
      // delimiters, so the plain text matches what HTML renders. Also
      // protects span content (e.g. Record<string, T>) from HTML stripping.
      const spans = [];
      let placeholder = '';
      for (let ci = 0; ci < line.length; ) {
        if (line[ci] === '`') {
          let openLen = 0;
          while (ci + openLen < line.length && line[ci + openLen] === '`') openLen++;
          let cj = ci + openLen;
          let found = false;
          while (cj < line.length) {
            if (line[cj] === '`') {
              let closeLen = 0;
              while (cj + closeLen < line.length && line[cj + closeLen] === '`') closeLen++;
              if (closeLen === openLen) {
                let span = line.slice(ci + openLen, cj);
                if (span.startsWith(' ') && span.endsWith(' ') && span.trim().length > 0) {
                  span = span.slice(1, -1);
                }
                spans.push(span);
                placeholder += `\x00${spans.length - 1}\x00`;
                ci = cj + closeLen;
                found = true;
                break;
              }
              cj += closeLen;
            } else {
              cj++;
            }
          }
          if (!found) {
            placeholder += line.slice(ci, ci + openLen);
            ci += openLen;
          }
        } else {
          placeholder += line[ci];
          ci++;
        }
      }
      const htmlStripped = placeholder.replace(/<[^>]+>/g, '');
      stripped = htmlStripped.replace(/\x00(\d+)\x00/g, (_, i) => spans[+i]);

      // Strip remaining inline formatting so plain text matches HTML extraction.
      // Bold: **text** or __text__ (process before italic)
      stripped = stripped.replace(/\*\*(.+?)\*\*/g, '$1');
      stripped = stripped.replace(/__(.+?)__/g, '$1');
      // Italic: *text* or _text_
      stripped = stripped.replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '$1');
      stripped = stripped.replace(/(?<!_)_([^_]+)_(?!_)/g, '$1');
    }
    if (/^\s*$/.test(stripped)) {
      if (!prevBlank && started) {
        out.push('');
        prevBlank = true;
      }
    } else {
      out.push(stripped);
      prevBlank = false;
      started = true;
    }
  }

  while (out.length > 0 && out[out.length - 1] === '') out.pop();
  return out.join('\n') + '\n';
}

const llmsDirective =
  '> For AI agents: a documentation index is available at /llms.txt\n\n';

const srcFiles = findMdFiles(docsDir);
let count = 0;

for (const src of srcFiles) {
  const dest = join(distDir, relative(docsDir, src));
  mkdirSync(dirname(dest), { recursive: true });

  const content = readFileSync(src, 'utf8');
  const { yaml, body } = splitFrontmatter(content);

  let output;
  if (yaml !== null && yaml.match(/^layout:\s*home$/m)) {
    output = homeYamlToMarkdown(yaml) + processBody(body);
  } else if (yaml !== null) {
    output = processBody(body);
  } else {
    output = processBody(content);
  }

  writeFileSync(dest, llmsDirective + output);
  count++;
}

console.log(`Generated agent markdown for ${count} pages in ${distDir}`);
